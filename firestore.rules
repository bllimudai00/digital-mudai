
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default: Allow read for authenticated users, deny all writes.
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }

    // USERS collection
    match /users/{userId} {
      // 1. A user can create their own document. THIS IS THE FIX.
      allow create: if request.auth.uid == userId;
      
      // 2. A user can read their own data. Admins can read anyone's data.
      allow read: if request.auth.uid == userId || 
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      
      // 3. A user can update their own data. Referral earnings are handled by server logic.
      allow update: if request.auth.uid == userId;
      
      // 4. Only admins can delete users.
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // TASKS, SETTINGS, ROADMAP, WHITEPAPER, CONTEST
    // Only admins can write to these collections. All authenticated users can read.
    match /tasks/{taskId} {
      allow get, list: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /settings/global {
      allow get: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /roadmap/{phaseId} {
      allow list: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /whitepaper/{sectionId} {
      allow list: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    match /contest/settings {
       allow get: if request.auth != null;
       allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
