
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // PUBLIC-READ: collections that any user can read, but not write to.
    match /tasks/{taskId} {
      allow read: if request.auth != null;
    }
    match /settings/global {
      allow read: if request.auth != null;
    }
    match /roadmap/{phaseId} {
      allow read: if request.auth != null;
    }
    match /whitepaper/{sectionId} {
      allow read: if request.auth != null;
    }
    match /contest/settings {
      allow read: if request.auth != null;
    }
    
    // USER-SPECIFIC: Rules for the users collection
    match /users/{userId} {
      // Allow user creation by anyone (required for new user sign-up)
      allow create: if request.auth != null;
      
      // Users can read their own data, or admins can read anyone's data
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);

      // Users can only update their own document.
      allow update: if request.auth != null && request.auth.uid == userId;

      // Only admins can delete users.
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ADMIN-WRITE: Collections that only admins can write to.
    match /tasks/{taskId} {
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
     match /settings/global {
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    match /roadmap/{phaseId} {
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    match /whitepaper/{sectionId} {
       allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    match /contest/settings {
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
